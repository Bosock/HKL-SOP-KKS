# Einheitliche Formatierung ohne Werkzeug-Zwang — moderne Editoren lesen das
# automatisch (https://editorconfig.org). Hält den bewusst dichten, aber
# konsistenten Stil der Codebasis über verschiedene Rechner hinweg stabil.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.{yml,yaml}]
indent_size = 2

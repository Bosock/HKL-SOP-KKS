# Copy to .env on the server (~/hkl-sop-kks/.env) to override the compose defaults.
#
# The container runs behind the host's shared nginx-proxy + letsencrypt
# companion and is exposed only on the internal `proxy` network — there is no
# host port to configure. The proxy routes the public hostname to it and the
# companion issues the TLS certificate.
#
# Public hostname routed to this container by nginx-proxy:
VIRTUAL_HOST=sops.kardio.wiki
# Hostname Let's Encrypt issues the certificate for (usually == VIRTUAL_HOST):
LETSENCRYPT_HOST=sops.kardio.wiki
# Contact e-mail for the ACME account / expiry notices:
LETSENCRYPT_EMAIL=mail@severinfink.de

# Server-side state is persisted inside the container at /app/state and kept in
# the Docker volume "hkl-state" (see docker-compose.yml) — no config needed.
# It survives `docker compose pull && up -d`. To wipe all shared edits:
#   docker compose down && docker volume rm hkl-sop-kks_hkl-state

# GitHub OAuth configuration (optional, for user authentication):
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=https://sops.kardio.wiki/auth/github/callback

# Secret used to sign the login session cookie (HMAC). If unset, a random one
# is generated at each start — logins then reset on every restart/redeploy.
# Set a fixed value (e.g. `openssl rand -hex 32`) so sessions survive deploys:
SESSION_SECRET=
